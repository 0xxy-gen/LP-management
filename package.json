{
  "name": "namecard-scanner",
  "version": "2.0.0",
  "description": "Batch namecard scanner with dedup, syncs to Notion",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"npm --prefix client run dev\"",
    "start": "NODE_ENV=production node server/index.js",
    "build": "npm --prefix client install && npm --prefix client run build",
    "postinstall": "npm --prefix client install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@google/generative-ai": "^0.24.1",
    "@notionhq/client": "^2.2.15",
    "concurrently": "^8.2.2",
    "express": "^4.18.2",
    "jimp": "^1.6.0",
    "jsqr": "^1.4.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.33.0"
  }
}
